{
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://farm-management-api.vercel.app/api/v1/:path*"
    },
    {
      "source": "/health",
      "destination": "https://farm-management-api.vercel.app/health"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
